# Example environment variables for imsg-mcp.
#
# Copy this file to .env.local for your machine. .env.local is gitignored —
# never commit machine-specific paths or secrets.
#
# All paths default to local Mac locations if these are unset, so most users
# don't need any of these.

# Default mode for env-var resolution.
VITE_ENV=development

# Dev-mode flag. When set to "1":
#   - Exposes dev-only MCP tools (health_check, get_logs, get_last_send_error,
#     run_build, request_restart). End users running `imsg mcp` directly never
#     see these.
#   - Enables file logging to $TMPDIR/imsg-mcp/*.ndjson and the periodic
#     heap-monitor heartbeats. Without IMSG_DEV, the in-memory log buffer is
#     still populated but never written to disk.
# Leave commented-out on machines where you only consume the published bin.
IMSG_DEV=1

# Verbose logging (only relevant when IMSG_DEV=1). When set to "1":
#   - Heartbeats fire every 10s instead of every 60s.
#   - Every DB query duration is logged regardless of magnitude.
# IMSG_LOG_VERBOSE=1

# Path to the live Messages database. Defaults to ~/Library/Messages/chat.db
# VITE_IMSG_DB_PATH="/Users/yourname/Library/Messages/chat.db"

# Path to the live AddressBook database. Defaults to
# ~/Library/Application Support/AddressBook/AddressBook-v22.abcddb
# VITE_CONTACTS_DB_PATH="/Users/yourname/Library/Application Support/AddressBook/AddressBook-v22.abcddb"

# UUID of the AddressBook source containing your contacts (varies by machine).
# Find it with: ls ~/Library/Application\ Support/AddressBook/Sources/
# VITE_ADDRESS_BOOK_UUID="YOUR-UUID-HERE"

# Path where the slug store keeps thread-slug → chat-GUID mappings.
# Defaults to ~/.imsg-mcp/slugs.db
# VITE_SLUGS_DB_PATH="/Users/yourname/.imsg-mcp/slugs.db"

# Optional VCF file to compare against your AddressBook (for development).
# VITE_VCF_PATH=""

# ── Watchdog tuning (optional, see AGENTS.md for full table) ─────────────
# IMSG_EVENT_LOOP_KILL_MS=10000
# IMSG_MAX_RSS_MB=1024
# IMSG_RESTART_AFTER_MS=86400000

# ── TUI cache tuning (optional) ───────────────────────────────────────────
# IMSG_TUI_MSG_HARD_CAP=5000
# IMSG_TUI_CACHE_TTL_MS=600000

# Set to "1" to disable the Rust native module and use the TS fallback.
# IMSG_DISABLE_NATIVE=0
