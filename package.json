{
  "name": "imsg-mcp",
  "version": "1.0.0",
  "description": "MCP server for iMessage on macOS - enables AI agents to send/receive messages",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "imsg-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "mcp": "node dist/index.js",
    "start": "pnpm exec tsx scripts/cli-console.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build",
    "rebuild": "pnpm rebuild better-sqlite3"
  },
  "keywords": [
    "mcp",
    "imessage",
    "sms",
    "macos",
    "ai-agent",
    "applescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "imessage-parser": "^0.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=18"
  },
  "volta": {
    "node": "24.13.0"
  }
}
