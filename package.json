{
  "name": "imsg-mcp",
  "version": "1.0.0",
  "description": "MCP server for iMessage on macOS - enables AI agents to send/receive messages",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "imsg-mcp": "./dist/index.js",
    "imsg-cli": "./dist/cli.js",
    "imsg": "./dist/tui.js"
  },
  "files": [
    "dist",
    "README.md",
    "skills"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "mcp": "node --env-file=.env --env-file-if-exists=.env.local dist/index.js",
    "mcp:ai": "node --env-file=.env --env-file-if-exists=.env.ai dist/index.js",
    "dev:mcp": "tsx src/index.ts",
    "dev:mcp:watch": "nodemon --ext ts --exec 'tsx src/index.ts'",
    "start": "node --env-file=.env --env-file-if-exists=.env.local dist/cli.js",
    "debug": "node --env-file=.env --env-file-if-exists=.env.local dist/cli.js",
    "cli": "node --env-file=.env --env-file-if-exists=.env.local dist/cli.js",
    "tui": "node --env-file=.env --env-file-if-exists=.env.local dist/tui.js",
    "doctor": "node --env-file=.env --env-file-if-exists=.env.local dist/cli.js doctor",
    "test": "vitest run",
    "test:native": "vitest run --mode development",
    "test:watch": "vitest",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build",
    "rebuild": "pnpm rebuild better-sqlite3",
    "sync-env-data": "tsx scripts/sync-env-data.ts"
  },
  "keywords": [
    "mcp",
    "imessage",
    "sms",
    "macos",
    "ai-agent",
    "applescript"
  ],
  "author": "George G",
  "repository": {
    "type": "git",
    "url": "https://github.com/george43g/imsg-mcp.git"
  },
  "homepage": "https://github.com/george43g/imsg-mcp#readme",
  "bugs": {
    "url": "https://github.com/george43g/imsg-mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "bplist-parser": "^0.3.2",
    "commander": "^14.0.3",
    "fullscreen-ink": "^0.1.0",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.1",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=24",
    "npm": "not in use"
  },
  "volta": {
    "node": "24.13.0"
  },
  "packageManager": "pnpm@10.29.3"
}
